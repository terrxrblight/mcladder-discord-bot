# ─────────────────────────────────────────────────────────────
#  mcladder Discord bot — переменные окружения
#  Скопируй этот файл в .env и заполни значения.
# ─────────────────────────────────────────────────────────────

# === Discord ===
# 1) https://discord.com/developers/applications → New Application
# 2) вкладка "Bot" → Reset Token → вставь сюда:
DISCORD_TOKEN=

# General Information → Application ID:
DISCORD_CLIENT_ID=

# ID твоего сервера. Включи в Discord: Settings → Advanced → Developer Mode,
# затем ПКМ по серверу → Copy Server ID:
GUILD_ID=

# ID канала, где висит лидерборд (ПКМ по каналу → Copy Channel ID):
LEADERBOARD_CHANNEL_ID=

# ID публичного канала ленты результатов матчей (#match-results).
# Можно оставить пустым — тогда лента матчей просто не запустится.
MATCH_RESULTS_CHANNEL_ID=

# ID админского канала мод-лога банов (#mod-logs). Пусто → мод-лог выключен.
MOD_LOG_CHANNEL_ID=

# === Postgres (ranked_read, тот же VPS) ===
# Креды для read-only пользователя ranked_read — скопируй из RankedChat/config.yml
# (секция database) твоего сервера. Пусто → БД-фичи (привязка/роли/баны/онлайн) выкл.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rankedmc
DB_USER=ranked_read
DB_PASS=
DB_SSL=false

# === Авто-роли по рангу + Verified ===
# true → бот выдаёт роль по тиру (Wood..Netherite) и Verified тем, кто привязал MC
# на сайте. Требует: Server Members Intent (Dev Portal) + право Manage Roles +
# роль бота ВЫШЕ управляемых ролей. Недостающие роли бот создаёт сам.
ROLE_SYNC=false
# Как часто пересинхронизировать роли, мин (1..60). pm2 restart форсит сразу.
ROLE_SYNC_MINUTES=5
ROLE_AUTOCREATE=true
VERIFIED_ROLE_NAME=Verified

# === Авто-бейдж Discord-бустера ===
# true → бот раз в ROLE_SYNC_MINUTES шлёт на сайт список бустящих сейчас, сайт
# выставляет/снимает авто-бейдж бустера (players.discord_booster). Ручная галочка
# в админке больше не нужна. Требует Server Members Intent (как и роли) и секрет ниже.
BOOSTER_SYNC=false
# Общий секрет server-to-server — должен СОВПАДАТЬ с BOT_SYNC_SECRET в .env API.
# Сгенерировать: openssl rand -hex 32
BOT_SYNC_SECRET=

# === API mcladder (по умолчанию прод — менять не нужно) ===
API_BASE=https://mcladder.com/api
SITE_BASE=https://mcladder.com

# === Тюнинг лидерборда ===
# Сколько мест показывать (1..25):
LEADERBOARD_LIMIT=10
# Как часто опрашивать /api/version на свежесть данных, мс (минимум 5000):
POLL_INTERVAL_MS=15000
